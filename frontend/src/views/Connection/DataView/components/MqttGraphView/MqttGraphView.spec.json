{
  "$schema": "../../../../../design-system/component-spec.schema.json",
  "name": "MqttGraphView",
  "tier": "view",
  "description": "Volume-weighted tidy-tree topic explorer (PixiJS): node size = message rate, colour = recency, with collapse, pan/zoom, minimap and follow-hottest.",
  "status": "story-only",
  "figma": {
    "fileKey": "",
    "nodeId": "",
    "url": "",
    "lastSyncedHash": null,
    "lastSyncedAt": null
  },
  "props": [
    {
      "name": "connection",
      "type": "object",
      "required": true
    },
    {
      "name": "selectedTopicStore",
      "type": "object",
      "required": true
    },
    {
      "name": "initialData",
      "type": "object",
      "required": false
    },
    {
      "name": "width",
      "type": "number",
      "required": false,
      "default": "0"
    },
    {
      "name": "messageSource",
      "type": "object",
      "required": false
    }
  ],
  "tokens": [
    "secondary-text",
    "outline",
    "elevation-0",
    "elevation-1",
    "elevation-2",
    "emphasis",
    "white-text",
    "primary",
    "hovered"
  ],
  "dependencies": [
    "PanelHeader",
    "BaseInput",
    "Button",
    "Icon",
    "Tooltip",
    "DropdownMenu",
    "DropdownMenuItem"
  ],
  "notes": "Figma page: Topic Graph — Exploration (Direction D). Canvas renderer; story mounts the real Pixi canvas on live mock traffic. Hover inspector shows msg/s + last-message age; legend explains recency ramp and sizing."
}
